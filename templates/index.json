        "custom_liquid": "<section class=\"rockals-blog-section\">\n  <div class=\"blog-head\">\n    <span>ROCKALS JOURNAL</span>\n    <h2>Latest From Our Blog</h2>\n    <p>Style tips, sneaker care guides, and latest fashion updates.</p>\n  </div>\n\n  <div class=\"blog-grid\">\n    <a href=\"/blogs/news/how-to-style-sneakers\" class=\"blog-card\">\n      <img src=\"https://i.pinimg.com/1200x/28/8d/c3/288dc32270b37c9122125d71a6d08490.jpg\" alt=\"Sneaker Styling\">\n      <div class=\"blog-content\">\n        <span>SNEAKER STYLE</span>\n        <h3>How To Style Sneakers With Everyday Outfits</h3>\n        <p>Discover easy ways to pair sneakers with casual, streetwear, and premium looks.</p>\n        <button>Read More →</button>\n      </div>\n    </a>\n\n    <a href=\"/blogs/news/sneaker-care-guide\" class=\"blog-card\">\n      <img src=\"https://i.pinimg.com/1200x/9c/6b/77/9c6b778c3bf0d73a156bf404c009c9ae.jpg\" alt=\"Sneaker Care\">\n      <div class=\"blog-content\">\n        <span>CARE GUIDE</span>\n        <h3>How To Keep Your Sneakers Clean & Fresh</h3>\n        <p>Simple cleaning and maintenance tips to keep your sneakers looking new.</p>\n        <button>Read More →</button>\n      </div>\n    </a>\n\n    <a href=\"/blogs/news/best-sneakers-for-comfort\" class=\"blog-card\">\n      <img src=\"https://i.pinimg.com/736x/40/80/a0/4080a04455f755f6f0528102c32be49b.jpg\" alt=\"Comfort Sneakers\">\n      <div class=\"blog-content\">\n        <span>BEST PICKS</span>\n        <h3>Best Sneakers For All-Day Comfort</h3>\n        <p>Explore sneakers designed for comfort, durability, and daily wear.</p>\n        <button>Read More →</button>\n      </div>\n    </a>\n  </div>\n</section>\n\n<style>\n.rockals-blog-section{\n  padding:80px 20px;\n  background:#f7f7f7;\n}\n\n.blog-head{\n  text-align:center;\n  margin-bottom:50px;\n}\n\n.blog-head span{\n  font-size:12px;\n  letter-spacing:4px;\n  color:#777;\n  font-weight:700;\n}\n\n.blog-head h2{\n  font-size:48px;\n  margin:15px 0;\n  color:#111;\n}\n\n.blog-head p{\n  color:#666;\n  font-size:16px;\n}\n\n.blog-grid{\n  max-width:1300px;\n  margin:auto;\n  display:grid;\n  grid-template-columns:repeat(3,1fr);\n  gap:28px;\n}\n\n.blog-card{\n  background:#fff;\n  text-decoration:none;\n  color:#111;\n  border-radius:22px;\n  overflow:hidden;\n  box-shadow:0 15px 35px rgba(0,0,0,.08);\n  transition:.3s;\n}\n\n.blog-card:hover{\n  transform:translateY(-10px);\n}\n\n.blog-card img{\n  width:100%;\n  height:310px;\n  object-fit:cover;\n  display:block;\n}\n\n.blog-content{\n  padding:28px;\n}\n\n.blog-content span{\n  font-size:11px;\n  letter-spacing:3px;\n  font-weight:700;\n  color:#999;\n}\n\n.blog-content h3{\n  font-size:26px;\n  line-height:1.2;\n  margin:14px 0;\n}\n\n.blog-content p{\n  color:#666;\n  line-height:1.7;\n  margin-bottom:22px;\n}\n\n.blog-content button{\n  border:none;\n  background:#111;\n  color:#fff;\n  padding:13px 26px;\n  border-radius:40px;\n  font-weight:700;\n}\n\n@media(max-width:991px){\n  .blog-grid{\n    grid-template-columns:1fr;\n  }\n\n  .blog-head h2{\n    font-size:34px;\n  }\n}\n</style>",
