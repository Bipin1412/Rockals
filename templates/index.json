duct-card:hover img{\n  transform:scale(1.04);\n}\n\n.product-info{\n  position:absolute;\n  bottom:30px;\n  left:25px;\n  right:25px;\n  display:flex;\n  justify-content:space-between;\n  align-items:flex-start;\n}\n\n.product-info h3{\n  margin:0;\n  color:#111;\n  font-size:20px;\n  font-weight:700;\n  letter-spacing:1px;\n}\n\n.product-info span{\n  display:block;\n  margin-top:8px;\n  color:#999;\n  font-size:16px;\n}\n\n.price{\n  color:#111;\n  font-size:20px;\n  font-weight:700;\n}\n\n.badge{\n  position:absolute;\n  top:0;\n  left:0;\n  background:#ff6666;\n  color:#fff;\n  padding:10px 15px;\n  font-size:12px;\n  font-weight:700;\n  letter-spacing:.5px;\n  z-index:5;\n}\n\n@media(max-width:1200px){\n  .rockals-products{\n    grid-template-columns:repeat(2,1fr);\n  }\n}\n\n@media(max-width:768px){\n\n  .rockals-products{\n    grid-template-columns:1fr;\n  }\n\n  .product-card{\n    min-height:540px;\n  }\n\n  .product-card img{\n    height:380px;\n    padding:15px;\n  }\n\n  .product-info h3{\n    font-size:18px;\n  }\n\n  .price{\n    font-size:18px;\n  }\n\n}\n\n</style>",
