        "custom_liquid": "<section class=\"sneaker-showcase\">\n\n  <div class=\"products-grid\">\n    {% assign sneaker_collection = collections['sneaker'] %}\n    {% for product in sneaker_collection.products limit: 8 %}\n      <div class=\"product-card\">\n        <a href=\"{{ product.url }}\">\n          <img src=\"{{ product.featured_image | img_url: '500x500' }}\" alt=\"{{ product.title }}\">\n          <h4>{{ product.title }}</h4>\n          <p>₹{{ product.price | money_without_currency }}</p>\n        </a>\n      </div>\n    {% else %}\n      <p>No products found in this collection.</p>\n    {% endfor %}\n  </div>\n\n  <div class=\"gallery\">\n    <div class=\"gallery-left\">\n      <img src=\"https://i.pinimg.com/1200x/9c/6b/77/9c6b778c3bf0d73a156bf404c009c9ae.jpg\" alt=\"Aeres\">\n      <img src=\"https://i.pinimg.com/1200x/28/8d/c3/288dc32270b37c9122125d71a6d08490.jpg\" alt=\"Apex\">\n      <img src=\"https://i.pinimg.com/1200x/dc/fe/69/dcfe699dd74aa128d3b9072dad7837da.jpg\" alt=\"Aeon\">\n      <img src=\"https://i.pinimg.com/736x/40/80/a0/4080a04455f755f6f0528102c32be49b.jpg\" alt=\"X Lows\">\n    </div>\n    <div class=\"gallery-right\">\n      <img src=\"https://i.pinimg.com/1200x/9c/6b/77/9c6b778c3bf0d73a156bf404c009c9ae.jpg\" alt=\"Featured\">\n    </div>\n  </div>\n\n</section>\n\n<style>\n.sneaker-showcase {\n  max-width: 1400px;\n  margin: auto;\n  padding: 40px 20px;\n}\n\n.products-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 20px;\n  margin-bottom: 30px;\n}\n\n.product-card {\n  border: 1px solid #eee;\n  border-radius: 12px;\n  overflow: hidden;\n  background: #fff;\n}\n\n.product-card a {\n  text-decoration: none;\n  color: inherit;\n  display: block;\n}\n\n.product-card img {\n  width: 100%;\n  display: block;\n}\n\n.product-card h4 {\n  padding: 10px 15px 0;\n}\n\n.product-card p {\n  padding: 0 15px 15px;\n  font-weight: bold;\n}\n\n.gallery {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 15px;